---
import '../styles/global.css'
import { Constants } from '../config/constants'

interface Props {
  title: string
}

const { title } = Astro.props
const { mail, location, phones } = Constants

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Etimatic Packaging',
  image: 'https://etimatic.vercel.app/images/hero.png',
  '@id': 'https://etimatic.vercel.app/#localbusiness',
  url: 'https://etimatic.vercel.app/',
  telephone: phones[0]?.callNumber || '+34-968-796-550',
  email: mail,
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: location.address.split('.')[0] || 'C/ Lepanto 71, Bajo',
    addressLocality: 'Yecla',
    addressRegion: 'Murcia',
    postalCode: '30510',
    addressCountry: 'ES',
  },
  sameAs: [location.mapsUrl],
}
---

<!doctype html>
<html lang='es'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width' />
    <link rel='icon' type='image/png' href='/favicon/favicon-96x96.png' />
    <meta name='generator' content={Astro.generator} />
    <title>{title}</title>

    <meta
      name='description'
      content='Fabricantes de packaging personalizado, etiquetas adhesivas, cajas y bolsas de papel a medida en España. Más de 30 años ofreciendo soluciones de embalaje de calidad para comercio e industria.'
    />
    <link rel='canonical' href='https://etimatic.vercel.app/' />

    <!-- OpenGraph / Facebook -->
    <meta property='og:type' content='website' />
    <meta property='og:url' content='https://etimatic.vercel.app/' />
    <meta property='og:title' content='Etimatic | Packaging Personalizado y Etiquetas Adhesivas' />
    <meta
      property='og:description'
      content='Fabricantes de packaging personalizado, etiquetas adhesivas, cajas y bolsas de papel en España. Servicio técnico y personalizado.'
    />
    <meta property='og:image' content='https://etimatic.vercel.app/images/home_titulo.png' />

    <!-- Twitter -->
    <meta property='twitter:card' content='summary_large_image' />
    <meta property='twitter:url' content='https://etimatic.vercel.app/' />
    <meta property='twitter:title' content='Etimatic | Packaging Personalizado y Etiquetas Adhesivas' />
    <meta
      property='twitter:description'
      content='Fabricantes de packaging personalizado, etiquetas adhesivas, cajas y bolsas de papel en España. Servicio técnico y personalizado.'
    />
    <meta property='twitter:image' content='https://etimatic.vercel.app/images/home_titulo.png' />

    <script type='application/ld+json' set:html={JSON.stringify(schema)} />

    <!-- Global site tag (gtag.js) - Google Analytics -->
    <script async src='https://www.googletagmanager.com/gtag/js?id=G-0FMVBG47XE'></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || []
      function gtag() {
        dataLayer.push(arguments)
      }
      gtag('js', new Date())
      gtag('config', 'G-0FMVBG47XE', { debug_mode: true })
    </script>

    <!-- Hotjar Tracking Code for Etimatic -->
    <script is:inline>
      ;(function (h, o, t, j, a, r) {
        h.hj =
          h.hj ||
          function () {
            ;(h.hj.q = h.hj.q || []).push(arguments)
          }
        h._hjSettings = { hjid: 2688972, hjsv: 6 }
        a = o.getElementsByTagName('head')[0]
        r = o.createElement('script')
        r.async = 1
        r.src = t + h._hjSettings.hjid + j + h._hjSettings.hjsv
        a.appendChild(r)
      })(window, document, 'https://static.hotjar.com/c/hotjar-', '.js?sv=')
    </script>

    <link rel='apple-touch-icon' sizes='57x57' href='/favicon/apple-icon-57x57.png' />
    <link rel='apple-touch-icon' sizes='60x60' href='/favicon/apple-icon-60x60.png' />
    <link rel='apple-touch-icon' sizes='72x72' href='/favicon/apple-icon-72x72.png' />
    <link rel='apple-touch-icon' sizes='76x76' href='/favicon/apple-icon-76x76.png' />
    <link rel='apple-touch-icon' sizes='114x114' href='/favicon/apple-icon-114x114.png' />
    <link rel='apple-touch-icon' sizes='120x120' href='/favicon/apple-icon-120x120.png' />
    <link rel='apple-touch-icon' sizes='144x144' href='/favicon/apple-icon-144x144.png' />
    <link rel='apple-touch-icon' sizes='152x152' href='/favicon/apple-icon-152x152.png' />
    <link rel='apple-touch-icon' sizes='180x180' href='/favicon/apple-icon-180x180.png' />
    <link rel='icon' type='image/png' sizes='192x192' href='/favicon/android-icon-192x192.png' />
    <link rel='icon' type='image/png' sizes='32x32' href='/favicon/favicon-32x32.png' />
    <link rel='icon' type='image/png' sizes='96x96' href='/favicon/favicon-96x96.png' />
    <link rel='icon' type='image/png' sizes='16x16' href='/favicon/favicon-16x16.png' />
    <link rel='manifest' href='/manifest.json' />
    <meta name='msapplication-TileColor' content='#ffffff' />
    <meta name='msapplication-TileImage' content='/favicon/ms-icon-144x144.png' />
    <meta name='theme-color' content='#ffffff' />
  </head>
  <body>
    <slot />
    <div id='modal-root'></div>
  </body>
</html>
