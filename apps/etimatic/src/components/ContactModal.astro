---
import { Constants } from '../config/constants'
const { mail, location, phones } = Constants
---

<dialog
  id='contact-modal'
  class='z-100 h-full max-h-none w-full max-w-none border-none bg-transparent p-0 backdrop:bg-black/50'
>
  <div class='flex h-full w-full items-center justify-center'>
    <div class='relative m-4 flex max-h-[90vh] w-full max-w-5xl overflow-x-hidden overflow-y-auto bg-white shadow-2xl'>
      <button id='close-modal' class='absolute top-4 right-4 z-10 cursor-pointer border-none bg-transparent p-2'>
        <svg xmlns='http://www.w3.org/2000/svg' width='34' height='34' fill='#393939' viewBox='0 0 256 256'>
          <path
            d='M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z'
          ></path>
        </svg>
      </button>

      <div id='form-container' class='flex h-full w-full flex-row max-lg:flex-col'>
        <!-- Contact Info Panel -->
        <div class='bg-main flex flex-1 flex-col p-[3em] max-lg:justify-around max-lg:p-[20px_1em] max-lg:text-center'>
          <h2 class='text-accent text-3xl max-lg:mb-2'>CONTACTA CON NOSOTROS</h2>

          <div
            class='mt-[10em] flex flex-col gap-8 text-base font-medium text-white max-lg:mt-0 max-lg:gap-4 max-lg:text-sm'
          >
            <a
              href={location.mapsUrl}
              target='_blank'
              rel='noreferrer'
              class='hover:text-accent no-underline transition-colors'
            >
              {location.address}<br />{location.city}
            </a>
            <a href={`mailto:${mail}`} class='hover:text-accent no-underline transition-colors'>
              {mail}
            </a>
            <div class='flex flex-col gap-2'>
              {
                phones.map(({ display, callNumber }) => (
                  <a
                    href={`tel:${callNumber}`}
                    class='text-accent font-bold no-underline transition-opacity hover:opacity-80'
                  >
                    {display}
                  </a>
                ))
              }
            </div>
          </div>
        </div>

        <!-- Form Panel -->
        <div class='flex min-h-100 flex-1 flex-col bg-white p-[3em] max-lg:p-8'>
          <div id='success-message' class='hidden flex-1 items-center justify-center'>
            <h2 class='text-accent text-center text-5xl font-semibold max-lg:text-xl'>
              Gracias, nos pondremos en contacto cuanto antes con usted
            </h2>
          </div>

          <form id='contact-form' class='flex h-full flex-col gap-8 max-lg:gap-4'>
            <h2 class='text-main text-5xl font-semibold max-lg:text-xl'>FORMULARIO</h2>

            <input
              type='text'
              name='name'
              placeholder='Nombre*'
              required
              class='border-main focus:border-accent w-full border-b-2 p-4 transition-colors outline-none'
            />
            <input
              type='email'
              name='email'
              placeholder='Mail*'
              required
              class='border-main focus:border-accent w-full border-b-2 p-4 transition-colors outline-none'
            />
            <textarea
              name='message'
              placeholder='Tu mensaje'
              class='border-main focus:border-accent min-h-30 w-full border-b-2 p-4 transition-colors outline-none'
            ></textarea>

            <div class='mt-auto flex items-center justify-between max-lg:justify-center'>
              <a
                href={`mailto:${mail}`}
                class='text-main text-base font-medium no-underline max-lg:hidden max-lg:text-sm'
              >
                {mail}
              </a>
              <button
                type='submit'
                class='bg-main hover:bg-accent hover:text-main min-w-[15em] rounded-full px-8 py-4 font-bold text-white transition-all max-lg:w-full'
              >
                Enviar
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</dialog>

<script>
  const modal = document.getElementById('contact-modal') as HTMLDialogElement
  const closeBtn = document.getElementById('close-modal')
  const form = document.getElementById('contact-form') as HTMLFormElement
  const formContainer = document.getElementById('contact-form')
  const successMsg = document.getElementById('success-message')

  window.addEventListener('open-contact-modal', () => {
    modal?.showModal()
    document.body.style.overflow = 'hidden'
  })

  const closeModal = () => {
    modal?.close()
    document.body.style.overflow = ''
    // Reset form state after some time
    setTimeout(() => {
      form?.classList.remove('hidden')
      successMsg?.classList.add('hidden')
      form?.reset()
    }, 500)
  }

  closeBtn?.addEventListener('click', closeModal)
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal()
  })

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const formData = new FormData(form)
    const data = {
      name: formData.get('name'),
      email: formData.get('email'),
      message: formData.get('message'),
    }

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(data),
      })

      if (res.ok) {
        form.classList.add('hidden')
        successMsg?.classList.remove('hidden')
        successMsg?.classList.add('flex')
      }
    } catch (err) {
      console.error('Error submitting form:', err)
      alert('Hubo un error al enviar el mensaje. Por favor, inténtelo de nuevo.')
    }
  })
</script>
