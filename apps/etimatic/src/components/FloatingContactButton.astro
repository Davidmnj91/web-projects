<button
  id='floating-contact-btn'
  class='shadow-main fixed right-12 bottom-12 z-40 h-12 w-12 cursor-pointer rounded-full shadow-2xl transition-all duration-300 outline-none hover:scale-110 active:scale-95 max-lg:right-4 max-lg:bottom-4'
  aria-label='Contactar con nosotros'
>
  <img src='/images/contact_us.png' width='48' alt='Contactanos' />
</button>

<script>
  const btn = document.getElementById('floating-contact-btn')
  btn?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('open-contact-modal'))
  })
</script>
