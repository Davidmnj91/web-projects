---
const CatalogItems = [
  {
    title: 'Embalaje Decorado',
    key: 'CATALOG_BOXES',
    image: '/images/catalog_boxes.png',
    url: '/catalogs/catalog_boxes.pdf',
  },
  {
    title: 'Bolsas Algodón y TNT',
    key: 'CATALOG_BAG_COTTON',
    image: '/images/catalog_bag_cotton.png',
    url: '/catalogs/catalog_bag_cotton.pdf',
  },
  {
    title: 'Bolsas Papel',
    key: 'CATALOG_BAG_PAPER',
    image: '/images/catalog_bag_paper.png',
    url: '/catalogs/catalog_bag_paper.pdf',
  },
  {
    title: 'Decoración',
    key: 'CATALOG_DECORATION',
    image: '/images/catalog_decoration.png',
    url: '/catalogs/catalog_decoration.pdf',
  },
  {
    title: 'Cintas Decorativas e Impresas',
    key: 'CATALOG_CINTAS',
    image: '/images/catalog_cintas.png',
    url: '/catalogs/catalog_cintas.pdf',
  },
  {
    title: 'Etiquetas Adhesivas',
    key: 'CATALOG_STICKERS',
    image: '/images/catalog_stickers.png',
    url: '/catalogs/catalog_stickers.pdf',
  },
  {
    title: 'Tendencias Etimatic',
    key: 'CATALOG_TRENDS',
    image: '/images/catalog_trends.png',
    url: '/catalogs/catalog_trends.pdf',
  },
  {
    title: 'Papel Regalo',
    key: 'CATALOG_GIFTS',
    image: '/images/catalog_paper.png',
    url: '/catalogs/catalog_paper.pdf',
  },
]
---

<section id='products' class='flex w-full flex-col items-center px-[5em] pb-[5em] max-lg:px-4 max-lg:pb-[3em]'>
  <div class='border-main my-[3em] hidden w-full border-t max-lg:block'></div>
  <h2 class='mb-10 text-center text-6xl font-extrabold max-lg:text-4xl'>NUESTRO PRODUCTO</h2>

  <div class='grid w-full grid-cols-1 gap-x-8 gap-y-12 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4'>
    {
      CatalogItems.map((catalog) => (
        <div class='group flex flex-col items-center'>
          <h3 class='group-hover:text-accent mb-4 flex min-h-12 items-center text-center text-xl font-medium transition-colors duration-300 max-lg:text-base'>
            {catalog.title}
          </h3>
          <div class='mb-5 h-75 w-full overflow-hidden rounded-lg'>
            <div
              class='h-full w-full bg-contain bg-center bg-no-repeat transition-transform duration-500 group-hover:scale-105'
              style={`background-image: url(${catalog.image})`}
            />
          </div>
          <a
            href={catalog.url}
            target='_blank'
            class='catalog-link bg-main hover:bg-accent hover:text-main w-full max-w-100 rounded-full px-8 py-3 text-center font-bold text-white no-underline shadow-md transition-all duration-300 ease-in-out hover:shadow-lg active:scale-95 max-lg:w-[90%]'
            data-key={catalog.key}
          >
            Ver Catálogo
          </a>
        </div>
      ))
    }
  </div>
</section>

<script>
  const catalogLinks = document.querySelectorAll('.catalog-link')
  catalogLinks.forEach((link) => {
    link.addEventListener('click', () => {
      const key = link.getAttribute('data-key')
      // @ts-ignore
      window.dataLayer?.push({ event: 'catalog_viewed', catalog_name: key })
    })
  })
</script>
