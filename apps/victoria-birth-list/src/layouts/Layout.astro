---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  isAdmin?: boolean
}

const {
  title = 'Lista de Nacimiento de Victoria 🍼',
  description = 'Gracias por querer formar parte de esta nueva etapa. Hemos preparado esta pequeña lista con algunas cosas que nos vendrían bien para la llegada de Victoria.',
  isAdmin = false,
} = Astro.props
---

<!doctype html>
<html lang='es'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <link
      rel='icon'
      type='image/svg+xml'
      href='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🍼</text></svg>'
    />
    <meta name='generator' content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name='title' content={title} />
    <meta name='description' content={description} />

    <!-- Open Graph / Facebook -->
    <meta property='og:type' content='website' />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />

    <!-- Twitter -->
    <meta property='twitter:card' content='summary_large_image' />
    <meta property='twitter:title' content={title} />
    <meta property='twitter:description' content={description} />
  </head>
  <body class="bg-background selection:bg-blush selection:text-blush-foreground flex min-h-screen flex-col justify-between">
    <!-- Main Content Area -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Shipping Section (Envíos) - Elegant Lovable layout, hidden on admin routes to prevent redundancy -->
    {!isAdmin && (
      <section class="mx-auto max-w-3xl px-5 py-20 text-center sm:py-28 border-t border-border/40">
        <p class="text-[11px] uppercase tracking-[0.28em] text-taupe font-medium">Envío</p>
        <h2 class="mt-2 text-3xl sm:text-4xl text-foreground font-serif">¿Prefieres enviarlo?</h2>
        <p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-muted-foreground">
          Por privacidad, no hemos publicado la dirección completa en la web. Si quieres mandarlo directamente, escríbenos o llámanos y te la facilitaremos encantados.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
          <a 
            href="tel:695267680" 
            class="inline-flex items-center gap-2 rounded-full bg-primary px-7 py-4 text-xs font-semibold uppercase tracking-wider text-primary-foreground transition-all hover:bg-primary/90 hover:shadow-md cursor-pointer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone h-4 w-4" aria-hidden="true"><path d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384"></path></svg>
            María José: 695 26 76 80
          </a>
          <a 
            href="tel:672258429" 
            class="inline-flex items-center gap-2 rounded-full bg-primary px-7 py-4 text-xs font-semibold uppercase tracking-wider text-primary-foreground transition-all hover:bg-primary/90 hover:shadow-md cursor-pointer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone h-4 w-4" aria-hidden="true"><path d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384"></path></svg>
            David: 672 25 84 29
          </a>
        </div>
      </section>
    )}

    <!-- Global Footer - Ultra minimalist and readable matching Lovable styles -->
    <footer class="border-t border-border/70 bg-background">
      <div class="mx-auto flex max-w-6xl flex-col items-center gap-3 px-5 py-10 text-center text-xs text-muted-foreground sm:flex-row sm:justify-between sm:text-left">
        <p>Hecho con cariño para Victoria &middot; {new Date().getFullYear()}</p>
        
        {isAdmin ? (
          <a href="/api/auth/logout" class="text-[11px] uppercase tracking-[0.2em] text-taupe hover:text-foreground transition-colors font-medium">Cerrar Sesión</a>
        ) : (
          <a href="/admin" class="text-[11px] uppercase tracking-[0.2em] text-taupe hover:text-foreground transition-colors font-medium">Admin</a>
        )}
      </div>
    </footer>
  </body>
</html>
