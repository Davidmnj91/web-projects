---
import { X } from '@lucide/astro'
---

<dialog
  id='form-modal'
  class='glass-panel animate-in fade-in zoom-in fixed inset-0 m-auto w-[92%] max-w-lg overflow-hidden rounded-2xl border-0 p-0 shadow-2xl duration-200 backdrop:bg-black/45 focus:outline-none'
>
  <div class='bg-primary text-primary-foreground relative px-6 py-7 text-center'>
    <h3 class='font-serif text-xl font-medium tracking-wide' id='form-modal-title'>Formulario de Reserva</h3>
    <p class='mt-1.5 text-xs opacity-85' id='form-modal-subtitle'>Introduce tus datos para que sepamos quién eres</p>
    <button
      id='close-form-btn'
      class='text-primary-foreground absolute top-4 right-4 cursor-pointer border-0 bg-transparent transition-opacity hover:opacity-70'
    >
      <X class='h-5 w-5' />
    </button>
  </div>

  <div class='p-8'>
    <!-- Error notice -->
    <div
      id='form-error-alert'
      class='bg-brand-red-light border-brand-red/20 text-brand-red mb-5 hidden rounded-xl border p-4 text-xs font-semibold'
    >
    </div>

    <!-- Main Form -->
    <form id='reservation-form' class='space-y-4'>
      <input type='hidden' id='form-gift-id' name='giftId' />
      <input type='hidden' id='form-type' name='type' />

      <div>
        <label for='form-name' class='text-foreground mb-2 block text-[10px] font-semibold tracking-wider uppercase'
          >Tu Nombre / Firma *</label
        >
        <input
          type='text'
          id='form-name'
          name='name'
          required
          placeholder='Ej. Tíos María y Carlos'
          class='focus:border-primary focus:ring-primary border-border w-full rounded-xl border bg-white px-4 py-3 text-sm transition-colors focus:ring-1 focus:outline-none'
        />
      </div>

      <div>
        <label for='form-email' class='text-foreground mb-2 block text-[10px] font-semibold tracking-wider uppercase'
          >Tu Correo Electrónico *</label
        >
        <input
          type='email'
          id='form-email'
          name='email'
          required
          placeholder='Ej. carlos@email.com'
          class='focus:border-primary focus:ring-primary border-border w-full rounded-xl border bg-white px-4 py-3 text-sm transition-colors focus:ring-1 focus:outline-none'
        />
        <p class='text-muted-foreground mt-1 text-[10px] leading-relaxed'>
          Te enviaremos un correo electrónico de confirmación con los enlaces para gestionar, modificar o cancelar tu
          detalle de forma automática.
        </p>
      </div>

      <div>
        <label for='form-message' class='text-foreground mb-2 block text-[10px] font-semibold tracking-wider uppercase'
          >Mensaje o Dedicatoria para Victoria (Opcional)</label
        >
        <textarea
          id='form-message'
          name='message'
          rows='3'
          placeholder='¡Enhorabuena papis! Esperamos con muchas ganas...'
          class='focus:border-primary focus:ring-primary border-border w-full resize-none rounded-xl border bg-white px-4 py-3 text-sm transition-colors focus:ring-1 focus:outline-none'
        ></textarea>
      </div>

      <button
        type='submit'
        id='form-submit-btn'
        class='bg-primary hover:bg-primary/90 text-primary-foreground flex w-full cursor-pointer items-center justify-center gap-1.5 rounded-full py-3.5 text-center text-sm font-semibold tracking-wide shadow-xs transition-all hover:shadow-md'
      >
        Confirmar Detalle ➔
      </button>
    </form>

    <!-- SUCCESS SCREEN (initially hidden) -->
    <div id='form-success-screen' class='hidden py-6 text-center'>
      <div
        class='bg-secondary border-border mx-auto mb-4 flex h-16 w-16 animate-bounce items-center justify-center rounded-full border'
      >
        <span class='text-2xl'>🎉</span>
      </div>
      <h3 class='text-foreground mb-2 font-serif text-xl font-medium tracking-wide'>¡Detalle registrado con éxito!</h3>

      <p class='text-muted-foreground mx-auto mb-4 max-w-xs text-sm leading-relaxed'>
        ¡Hola <span id='success-guest-name' class='text-foreground font-bold'></span>! Hemos completado el registro de
        tu detalle para la llegada de Victoria.
      </p>

      <div class='bg-secondary/40 border-border/60 mx-auto mb-5 max-w-sm rounded-xl border p-4 text-left'>
        <p class='text-foreground text-xs'>🏷️ <strong>Tu identificador único de reserva:</strong></p>
        <p
          class='text-primary border-border mt-1 rounded-lg border bg-white py-1.5 text-center font-mono text-sm font-bold tracking-wide'
          id='success-funny-id'
        >
        </p>
      </div>

      <p class='text-muted-foreground mx-auto max-w-xs text-xs leading-relaxed'>
        Te hemos enviado un correo a <strong id='success-guest-email' class='text-foreground'></strong> con los enlaces rápidos
        para confirmar tu compra o cancelarla si fuera necesario. ¡Gracias por tu cariño!
      </p>

      <button
        type='button'
        id='btn-success-close'
        class='bg-primary hover:bg-primary/90 text-primary-foreground mt-8 cursor-pointer rounded-full px-8 py-2.5 text-sm font-semibold tracking-wide shadow-xs transition-all'
      >
        Entendido, cerrar
      </button>
    </div>
  </div>
</dialog>
