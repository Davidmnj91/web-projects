---
import Layout from '../../../layouts/Layout.astro';
import { db, initDb } from '../../../lib/db';
import { sendReservationEmail } from '../../../lib/email';

const { id } = Astro.params;

let errorMsg = '';
let successMsg = '';
let resData: {
  id: string;
  name: string;
  email: string;
  giftId: string;
  giftTitle: string;
  status: string;
  message: string;
} | null = null;

try {
  await initDb();

  // 1. Fetch Reservation Details
  const result = await db.execute({
    sql: `
      SELECT r.id, r.name, r.email, r.giftId, r.status, r.message, g.title as giftTitle
      FROM reservations r
      JOIN gifts g ON r.giftId = g.id
      WHERE r.id = ?
      LIMIT 1
    `,
    args: [id || '']
  });

  if (result.rows.length === 0) {
    errorMsg = 'No hemos encontrado ninguna reserva con ese identificador. Por favor, comprueba el enlace de tu correo.';
  } else {
    const row = result.rows[0];
    resData = {
      id: row.id as string,
      name: row.name as string,
      email: row.email as string,
      giftId: row.giftId as string,
      status: row.status as string,
      message: (row.message as string) || '',
      giftTitle: row.giftTitle as string,
    };
  }

  // 2. Handle POST forms
  if (Astro.request.method === 'POST' && resData) {
    const formData = await Astro.request.formData();
    const action = formData.get('action')?.toString();
    const nameInput = formData.get('name')?.toString() || resData.name;
    const messageInput = formData.get('message')?.toString() || '';

    if (action === 'cancel') {
      // Transition to Cancelled
      await db.execute({
        sql: 'UPDATE reservations SET status = "Cancelled" WHERE id = ?',
        args: [id || '']
      });
      return Astro.redirect(`/reservation/${id}/cancel`);
    }

    if (action === 'purchase' && resData.status === 'Reserved') {
      // Transition to Purchased
      const newTimestamp = Date.now();
      await db.execute({
        sql: 'UPDATE reservations SET status = "Purchased", name = ?, message = ?, timestamp = ? WHERE id = ?',
        args: [nameInput, messageInput, newTimestamp, id || '']
      });
      
      // Update local state
      resData.status = 'Purchased';
      resData.name = nameInput;
      resData.message = messageInput;

      // Send confirmation email
      const domainUrl = new URL(Astro.request.url).origin;
      await sendReservationEmail({
        name: nameInput,
        email: resData.email,
        giftTitle: resData.giftTitle,
        reservationId: resData.id,
        isPurchase: true,
        domainUrl
      });

      successMsg = '¡Muchísimas gracias! El detalle ha sido marcado como COMPRADO de forma definitiva. Te hemos enviado un correo de confirmación.';
    }

    if (action === 'save_changes' && resData.status === 'Purchased') {
      // Update name and message for purchased gift
      await db.execute({
        sql: 'UPDATE reservations SET name = ?, message = ? WHERE id = ?',
        args: [nameInput, messageInput]
      });

      resData.name = nameInput;
      resData.message = messageInput;
      successMsg = '¡Tus cambios han sido guardados correctamente!';
    }
  }
} catch (e) {
  console.error('Confirm page error:', e);
  errorMsg = 'Ha ocurrido un error al procesar la información. Inténtalo de nuevo más tarde.';
}
---

<Layout title="Confirmar Detalle | Victoria 🍼">
  <div class="max-w-xl mx-auto px-4 py-16">
    <div class="glass-panel rounded-2xl shadow-xl overflow-hidden border border-white">
      
      <!-- Top banner depending on status -->
      {resData && (
        <div class={`px-6 py-8 text-center text-white bg-gradient-to-r ${resData.status === 'Reserved' ? 'from-brand-amber to-brand-terracotta' : 'from-brand-olive-dark to-brand-olive'}`}>
          <span class="text-4xl">{resData.status === 'Reserved' ? '🎁' : '💖'}</span>
          <h1 class="text-2xl font-bold font-display mt-2">
            {resData.status === 'Reserved' ? 'Confirmar Compra' : '¡Detalle Confirmado!'}
          </h1>
          <p class="text-sm opacity-90 mt-1">Identificador: <span class="font-mono text-xs font-bold bg-black/25 px-2 py-0.5 rounded-sm">{id}</span></p>
        </div>
      )}

      {!resData && (
        <div class="bg-brand-red px-6 py-8 text-center text-white">
          <span class="text-4xl">⚠️</span>
          <h1 class="text-2xl font-bold font-display mt-2">Error de Enlace</h1>
        </div>
      )}

      <div class="p-8">
        <!-- Error Alerts -->
        {errorMsg && (
          <div class="bg-brand-red-light border border-brand-red/20 rounded-xl p-6 text-center">
            <p class="text-brand-red font-medium text-sm">{errorMsg}</p>
            <a href="/" class="inline-block mt-4 text-xs font-semibold text-text-charcoal hover:underline">Volver a la página de inicio</a>
          </div>
        )}

        <!-- Success Toast-like Alerts -->
        {successMsg && (
          <div class="bg-brand-sage border border-brand-olive/30 rounded-xl p-5 mb-6 text-center text-brand-olive-dark">
            <p class="text-sm font-semibold leading-relaxed">{successMsg}</p>
          </div>
        )}

        {resData && (
          <div>
            {resData.status === 'Cancelled' ? (
              <div class="text-center py-6">
                <div class="w-16 h-16 bg-brand-red-light rounded-full flex items-center justify-center mx-auto mb-4 border border-brand-red/30">
                  <span class="text-xl">✕</span>
                </div>
                <h2 class="text-lg font-bold font-display text-text-charcoal mb-2">Esta reserva ha sido cancelada</h2>
                <p class="text-sm text-text-muted max-w-sm mx-auto mb-6">
                  El regalo <strong>"{resData.giftTitle}"</strong> se encuentra disponible nuevamente en el catálogo público para que otros invitados puedan elegirlo.
                </p>
                <a href="/" class="inline-block bg-brand-terracotta text-white font-semibold text-sm px-6 py-2.5 rounded-xl hover:bg-brand-terracotta-dark transition-all">
                  Volver a la Lista de Regalos
                </a>
              </div>
            ) : resData.status === 'Reserved' ? (
              /* --- STATE: RESERVED --- */
              <div>
                <p class="text-sm text-text-muted leading-relaxed mb-6">
                  ¡Hola! Has reservado el detalle <strong class="text-text-charcoal">"{resData.giftTitle}"</strong>. Si ya lo has comprado en tu tienda de confianza, puedes marcarlo como comprado aquí para confirmarlo definitivamente.
                </p>

                <div class="bg-brand-amber-light/35 border border-brand-amber/15 rounded-xl p-5 mb-8">
                  <span class="text-xs font-bold text-brand-terracotta uppercase tracking-wider">Detalle Reservado</span>
                  <h3 class="text-lg font-bold font-display text-text-charcoal mt-1">{resData.giftTitle}</h3>
                  <p class="text-xs text-text-muted mt-2">Correo asociado: <strong>{resData.email}</strong> (No editable)</p>
                </div>

                <form method="POST" class="space-y-6">
                  <input type="hidden" name="action" value="purchase" />

                  <!-- Name Input -->
                  <div>
                    <label for="name" class="block text-xs font-bold text-text-charcoal uppercase tracking-wider mb-2">Tu Nombre / Firma</label>
                    <input 
                      type="text" 
                      id="name" 
                      name="name" 
                      value={resData.name} 
                      required 
                      class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-brand-terracotta focus:ring-1 focus:ring-brand-terracotta transition-colors"
                      placeholder="Ej. Tía Luisa"
                    />
                  </div>

                  <!-- Message Input -->
                  <div>
                    <label for="message" class="block text-xs font-bold text-text-charcoal uppercase tracking-wider mb-2">Mensaje / Dedicatoria para Victoria (Opcional)</label>
                    <textarea 
                      id="message" 
                      name="message" 
                      rows="4" 
                      class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-brand-terracotta focus:ring-1 focus:ring-brand-terracotta transition-colors resize-none"
                      placeholder="Escribe unas palabras bonitas para el recuerdo de María José y David..."
                    >{resData.message}</textarea>
                  </div>

                  <!-- Action Buttons -->
                  <div class="pt-4 space-y-3">
                    <button 
                      type="submit" 
                      class="w-full bg-brand-olive text-white font-semibold text-sm py-3.5 rounded-xl hover:bg-brand-olive-dark shadow-sm hover:shadow-md transition-all cursor-pointer text-center"
                    >
                      Confirmar Compra (Ya lo he comprado) ➔
                    </button>
                  </div>
                </form>

                <!-- Separate form for cancelling -->
                <form method="POST" class="mt-3">
                  <input type="hidden" name="action" value="cancel" />
                  <button 
                    type="submit" 
                    class="w-full bg-brand-red-light text-brand-red font-semibold text-sm py-3 rounded-xl hover:bg-brand-red hover:text-white transition-all cursor-pointer text-center border border-brand-red/10"
                  >
                    ✕ Cancelar Reserva (Liberar regalo)
                  </button>
                </form>
              </div>
            ) : (
              /* --- STATE: PURCHASED --- */
              <div>
                <div class="text-center py-4 mb-6">
                  <div class="w-12 h-12 bg-brand-sage rounded-full flex items-center justify-center mx-auto mb-3 border border-brand-olive/20">
                    <span class="text-xl">✨</span>
                  </div>
                  <h2 class="text-xl font-bold font-display text-brand-olive-dark">¡Victoria te da las gracias! 👶💖</h2>
                  <p class="text-sm text-text-muted mt-2 leading-relaxed">
                    Hemos registrado correctamente la compra de <strong>"{resData.giftTitle}"</strong> a nombre de <strong>{resData.name}</strong>. Nos hace muchísima ilusión recibir tu detalle.
                  </p>
                </div>

                <!-- Prefilled form to edit Name and Message -->
                <form method="POST" class="space-y-5 border-t border-gray-100 pt-6">
                  <input type="hidden" name="action" value="save_changes" />

                  <!-- Name Input -->
                  <div>
                    <label for="name" class="block text-xs font-bold text-text-charcoal uppercase tracking-wider mb-2">Tu Nombre / Firma</label>
                    <input 
                      type="text" 
                      id="name" 
                      name="name" 
                      value={resData.name} 
                      required 
                      class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-brand-olive focus:ring-1 focus:ring-brand-olive transition-colors"
                      placeholder="Ej. Tía Luisa"
                    />
                  </div>

                  <!-- Message Input -->
                  <div>
                    <label for="message" class="block text-xs font-bold text-text-charcoal uppercase tracking-wider mb-2">Mensaje / Dedicatoria</label>
                    <textarea 
                      id="message" 
                      name="message" 
                      rows="4" 
                      class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-brand-olive focus:ring-1 focus:ring-brand-olive transition-colors resize-none"
                      placeholder="Escribe tus buenos deseos..."
                    >{resData.message}</textarea>
                  </div>

                  <!-- Save Button -->
                  <button 
                    type="submit" 
                    class="w-full bg-brand-terracotta text-white font-semibold text-sm py-3 rounded-xl hover:bg-brand-terracotta-dark shadow-sm hover:shadow-md transition-all cursor-pointer text-center"
                  >
                    Guardar Cambios
                  </button>
                </form>

                <!-- Help / Contact Card -->
                <div class="bg-brand-sage/50 border border-brand-olive/20 rounded-xl p-5 mt-8">
                  <h4 class="font-display font-bold text-sm text-brand-olive-dark flex items-center gap-1.5">
                    <span>📞</span> ¿Tienes alguna duda o incidencia?
                  </h4>
                  <p class="text-xs text-text-muted mt-1 leading-relaxed">
                    Si te has equivocado al marcar el regalo, si necesitas cambiar de detalle o tienes problemas para enviarlo, ponte en contacto con nosotros directamente por teléfono o WhatsApp:
                  </p>
                  <div class="grid grid-cols-2 gap-3 mt-4 text-xs">
                    <div class="bg-white/80 p-2 rounded-lg border border-gray-100 flex flex-col">
                      <span class="text-text-muted">María José</span>
                      <a href="tel:695267680" class="font-bold text-brand-terracotta mt-0.5 hover:underline">695 26 76 80</a>
                    </div>
                    <div class="bg-white/80 p-2 rounded-lg border border-gray-100 flex flex-col">
                      <span class="text-text-muted">David</span>
                      <a href="tel:672258429" class="font-bold text-brand-terracotta mt-0.5 hover:underline">672 25 84 29</a>
                    </div>
                  </div>
                </div>
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>
