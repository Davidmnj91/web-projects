---
import Layout from '../../../layouts/Layout.astro'
import { db, initDb } from '../../../lib/db'

const { id } = Astro.params

let errorMsg = ''
let success = false
let resData: {
  id: string
  name: string
  email: string
  giftId: string
  giftTitle: string
  status: string
} | null = null

try {
  await initDb()

  // Fetch reservation and gift details
  const result = await db.execute({
    sql: `
      SELECT r.id, r.name, r.email, r.giftId, r.status, g.title as giftTitle
      FROM reservations r
      JOIN gifts g ON r.giftId = g.id
      WHERE r.id = ?
      LIMIT 1
    `,
    args: [id || ''],
  })

  if (result.rows.length === 0) {
    errorMsg = 'No hemos encontrado ninguna reserva con ese identificador. Por favor, comprueba el enlace de tu correo.'
  } else {
    const row = result.rows[0]
    resData = {
      id: row.id as string,
      name: row.name as string,
      email: row.email as string,
      giftId: row.giftId as string,
      status: row.status as string,
      giftTitle: row.giftTitle as string,
    }
  }

  // Handle post request to actually cancel
  if (Astro.request.method === 'POST' && resData && resData.status !== 'Cancelled') {
    await db.execute({
      sql: 'UPDATE reservations SET status = "Cancelled" WHERE id = ?',
      args: [id || ''],
    })
    resData.status = 'Cancelled'
    success = true
  }
} catch (e) {
  console.error('Cancel page error:', e)
  errorMsg = 'Ha ocurrido un error al cargar la información. Inténtalo de nuevo más tarde.'
}
---

<Layout title='Cancelar Reserva | Victoria 🍼'>
  <div class='mx-auto max-w-xl px-4 py-16'>
    <div class='glass-panel overflow-hidden rounded-2xl border border-white shadow-xl'>
      <!-- Title banner -->
      <div class='from-brand-terracotta to-brand-amber bg-gradient-to-r px-6 py-8 text-center text-white'>
        <span class='text-4xl'>✕</span>
        <h1 class='font-display mt-2 text-2xl font-bold'>Gestionar Reserva</h1>
        <p class='mt-1 text-sm opacity-90'>
          Identificador: <span class='rounded-sm bg-black/25 px-2 py-0.5 font-mono text-xs font-bold'>{id}</span>
        </p>
      </div>

      <div class='p-8'>
        {
          errorMsg && (
            <div class='bg-brand-red-light border-brand-red/20 rounded-xl border p-6 text-center'>
              <p class='text-brand-red text-sm font-medium'>{errorMsg}</p>
              <a href='/' class='text-text-charcoal mt-4 inline-block text-xs font-semibold hover:underline'>
                Volver a la página de inicio
              </a>
            </div>
          )
        }

        {
          !errorMsg && success && (
            <div class='py-6 text-center'>
              <div class='bg-brand-sage border-brand-olive/30 mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full border'>
                <span class='text-2xl'>🌿</span>
              </div>
              <h2 class='font-display text-brand-olive-dark mb-2 text-xl font-bold'>¡Reserva cancelada con éxito!</h2>
              <p class='text-text-muted mx-auto max-w-sm text-sm leading-relaxed'>
                Hola <strong>{resData?.name}</strong>, tu reserva para el regalo <strong>"{resData?.giftTitle}"</strong>{' '}
                ha sido cancelada.
              </p>
              <p class='text-text-muted mx-auto mt-3 max-w-sm text-xs'>
                El regalo vuelve a estar marcado como <strong>Disponible</strong> en la lista para que otros familiares
                y amigos puedan elegirlo. ¡Gracias por mantener la lista actualizada!
              </p>
              <div class='mt-8'>
                <a
                  href='/'
                  class='bg-brand-terracotta hover:bg-brand-terracotta-dark inline-block rounded-xl px-6 py-2.5 text-sm font-semibold text-white shadow-sm transition-all hover:shadow-md'
                >
                  Volver a la Lista de Regalos
                </a>
              </div>
            </div>
          )
        }

        {
          !errorMsg && !success && resData && (
            <div>
              {resData.status === 'Cancelled' ? (
                <div class='py-6 text-center'>
                  <div class='mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-gray-100'>
                    <span class='text-xl'>ℹ️</span>
                  </div>
                  <h2 class='font-display text-text-charcoal mb-2 text-lg font-bold'>Esta reserva ya está cancelada</h2>
                  <p class='text-text-muted mx-auto max-w-sm text-sm'>
                    La reserva para el regalo <strong>"{resData.giftTitle}"</strong> fue cancelada anteriormente y el
                    regalo ya se encuentra disponible de nuevo en la web.
                  </p>
                  <div class='mt-6'>
                    <a
                      href='/'
                      class='bg-brand-terracotta hover:bg-brand-terracotta-dark inline-block rounded-xl px-6 py-2.5 text-sm font-semibold text-white transition-all'
                    >
                      Ver Lista de Regalos
                    </a>
                  </div>
                </div>
              ) : (
                <div class='py-2'>
                  <p class='text-text-muted mb-6 text-sm leading-relaxed'>
                    Hola <strong class='text-text-charcoal'>{resData.name}</strong>, estás a punto de cancelar tu
                    reserva para el regalo:
                  </p>

                  <div class='bg-brand-amber-light/35 border-brand-amber/15 mb-8 rounded-xl border p-5'>
                    <span class='text-brand-terracotta text-xs font-bold tracking-wider uppercase'>
                      Regalo Reservado
                    </span>
                    <h3 class='font-display text-text-charcoal mt-1 text-lg font-bold'>{resData.giftTitle}</h3>
                    <div class='mt-3 flex items-center gap-2'>
                      <span class='bg-brand-amber rounded-md px-2 py-0.5 text-xs font-semibold text-white'>
                        {resData.status === 'Reserved' ? 'Reservado' : 'Comprado'}
                      </span>
                      <span class='text-text-muted text-xs'>Asociado a: {resData.email}</span>
                    </div>
                  </div>

                  <div class='bg-brand-red-light/40 border-brand-red/10 mb-8 rounded-xl border p-4'>
                    <p class='text-brand-red text-xs leading-relaxed'>
                      ⚠️ <strong>Atención:</strong> Al cancelar la reserva, el regalo volverá a aparecer como
                      "Disponible" en la web para que cualquier otra persona lo pueda reservar o comprar.
                    </p>
                  </div>

                  <form method='POST' class='flex flex-col gap-3 sm:flex-row'>
                    <a
                      href='/'
                      class='text-text-charcoal flex-1 rounded-xl bg-gray-100 px-5 py-3 text-center text-sm font-semibold transition-colors hover:bg-gray-200'
                    >
                      No, mantener reserva
                    </a>
                    <button
                      type='submit'
                      class='bg-brand-red flex-1 cursor-pointer rounded-xl px-5 py-3 text-sm font-semibold text-white shadow-sm transition-all hover:bg-red-600 hover:shadow-md'
                    >
                      Sí, cancelar mi reserva
                    </button>
                  </form>
                </div>
              )}
            </div>
          )
        }
      </div>
    </div>
  </div>
</Layout>
