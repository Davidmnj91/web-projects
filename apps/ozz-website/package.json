{
  "name": "ozz-website",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "dev": "astro dev",
    "format:check": "prettier \"**/*.{js,mjs,ts,tsx,astro,json,md,css}\" --list-different",
    "format:write": "prettier \"**/*.{js,mjs,ts,tsx,astro,json,md,css}\" --list-different --write",
    "lint": "eslint .  --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/sitemap": "catalog:astro",
    "@astrojs/vercel": "catalog:astro",
    "@tailwindcss/vite": "catalog:tailwind",
    "astro": "catalog:astro",
    "cloudinary": "catalog:cloudinary",
    "photoswipe": "catalog:",
    "tailwindcss": "catalog:tailwind"
  },
  "devDependencies": {
    "@web-projects/eslint": "workspace:*",
    "@web-projects/prettier": "workspace:*",
    "prettier-plugin-astro": "catalog:prettier",
    "prettier-plugin-tailwindcss": "catalog:prettier"
  }
}
