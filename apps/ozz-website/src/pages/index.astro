---
import Logo from "../components/logo.astro";
import Layout from '../layouts/Layout.astro'
export const prerender = false
---
<Layout headerOffset={412} title="Selected Work" description="My selected work">
  <div id="loader-overlay" class="fixed inset-0 z-100 flex items-center justify-center bg-white transition-opacity duration-1000">
    <div class="absolute inset-0 z-0">
      <img
        id="hero-loader-img"
        class="w-full h-full object-cover animate-focus-loop"
        src="/loading_bg.png"
        alt="loading"
      />
    </div>

    <div id="loader-logo" class="relative z-10 text-center">
      <Logo/>
    </div>
  </div>
  <section id="main-content" class="opacity-0 translate-y-10 transition-all duration-1000 mx-auto">
    <div
      id="gallery"
      class="hidden md:flex items-start gap-4 md:gap-8 w-full mx-auto py-10"
    >
      <div id="col-1" class="flex-1"></div>
      <div id="col-2" class="flex-1"></div>
    </div>
    <div id="gallery-mobile" class="md:hidden p-4"></div>
    <div id="sentinel" class="h-20 flex items-center justify-center mt-10">
      <div id="loader" class="hidden loading-indicator text-xs uppercase tracking-widest text-gray-400">Loading more...</div>
    </div>
  </section>
</Layout>

<style>
  @keyframes focus-loop {
    0%, 100% {
      filter: blur(25px);
      scale: 1.1;
    }
    50% {
      filter: blur(5px);
      scale: 1.02;
    }
  }
  .animate-focus-loop { animation: focus-loop 1s infinite ease-in-out; }
  .camera-shutter {
    animation: none !important;
    filter: blur(0);
    scale: 1 !important;
    transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1) !important;
    object-fit: contain !important;
  }
  .break-inside-avoid { break-inside: avoid; }
</style>

<script is:inline>
  const overlay = document.getElementById('loader-overlay');
  const content = document.getElementById('main-content');
  const heroImg = document.getElementById('hero-loader-img')

  const galleryMobile = document.getElementById("gallery-mobile")
  const col1 = document.getElementById("col-1")
  const col2 = document.getElementById("col-2")

  const sentinel = document.getElementById('sentinel')
  const loader = document.getElementById('loader')

  let nextCursor = undefined
  let isLoading = false
  let heroAnimationExecuted = false

  const checkFirstBatch = () => {
    if (!heroAnimationExecuted) {
      heroAnimationExecuted = true
      heroImg.classList.toggle('camera-shutter')
      setTimeout(() => {
        overlay.style.opacity = '0'
        overlay.style.pointerEvents = 'none'
        content.classList.remove('opacity-0', 'translate-y-10')
      }, 500);
    }
  }

  const addImagesToDom = (data) => {
    const getShortestColumn = () => (col1?.offsetHeight ?? 0) <= (col2?.offsetHeight ?? 0) ? col1 : col2
    const createImageCard = img => {
      const optimizedUrl = img.secure_url.replace('/upload/', '/upload/f_auto,q_auto,w_auto/')

      const anchorElement = document.createElement("a")
      anchorElement.href = img.secure_url
      anchorElement.setAttribute('data-pswp-width', img.width)
      anchorElement.setAttribute('data-pswp-height', img.height)
      anchorElement.className = "block group relative overflow-hidden bg-gray-100 mb-4 md:mb-8 break-inside-avoid"

      anchorElement.innerHTML = `
    <img
      src="${optimizedUrl}"
      alt="Photography by Oscar Zamora"
      width="${img.width}"
      height="${img.height}"
      loading="lazy"
      decoding="async"
      onload="checkFirstBatch()"
      class="w-full h-auto object-cover transition-transform duration-700 ease-out group-hover:scale-105"
    />
    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-500 pointer-events-none"></div>
  `

      return anchorElement
    }

    const cards = (data ?? []).map(createImageCard)
    cards.forEach(card => {
      galleryMobile?.appendChild(card)
      getShortestColumn()?.appendChild(card)
    })
    if (window.refreshLightbox) {
      window.refreshLightbox(cards);
    }
  }


  async function loadNextBatch() {
    if (!isLoading) {
      isLoading = true
      try {
        loader?.classList.remove('hidden')
        const url = `/api/images${nextCursor ? `?next_cursor=${encodeURIComponent(nextCursor)}` : ''}`
        const response = await fetch(url)
        const { resources, next_cursor } = await response.json()

        addImagesToDom(resources)
        nextCursor = next_cursor
      } catch (error) {
        console.error('Error loading images:', error)
      } finally {
        isLoading = false
        if (!nextCursor) {
          observer.unobserve(sentinel)
          sentinel.remove()
        } else {
          loader?.classList.add('hidden')
        }
      }
    }
  }

  const observer = new IntersectionObserver(async (entries) => {
    if (entries[0].isIntersecting) {
      await loadNextBatch(entries)
    }
  }, { rootMargin: "400px" })

  if (sentinel) observer.observe(sentinel)

  window.addEventListener('load-more-photos', loadNextBatch);
</script>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#main-content',
    children: 'a',
    pswpModule: () => import('photoswipe'),
    padding: { top: 0, bottom: 0, left: 0, right: 0 },
    initialZoomLevel: 'fill',
    zoom: false,
    counter: false,
    arrowPrev: false,
    arrowNext: false,
    close: false,
  });

  // Detectar cuando el usuario pasa fotos dentro del Lightbox
  lightbox.on('change', () => {
    const pswp = lightbox.pswp;
    const currIndex = pswp.currIndex;
    const totalItems = pswp.getNumItems();

    // Si faltan 2 fotos para llegar al final del batch actual...
    if (currIndex >= totalItems - 2) {
      // Disparamos el evento global para que el Infinite Scroll cargue más
      window.dispatchEvent(new CustomEvent('load-more-photos'));
    }
  });

  lightbox.on('uiRegister', function() {
    // Botón de Cerrar Personalizado
    lightbox.pswp?.ui?.registerElement({
      name: 'author',
      appendTo: 'wrapper',
      html: '<div class="custom-name-col">OSCAR ZAMORA</div>',
    });

    lightbox.pswp?.ui?.registerElement({
      name: 'custom_close',
      appendTo: 'wrapper',
      ariaLabel: 'Cerrar galería',
      isButton: true,
      html: `<span>CLOSE X</span>`,
      onClick: (event, el, pswp) => {
        pswp.close();
      }
    });

    lightbox.pswp?.ui?.registerElement({
      name: 'controls',
      appendTo: 'wrapper',
      html: `
        <div class="custom-nav-col">
          <div class="flex gap-2 text-sm tracking-tighter uppercase font-medium">
            <button id="pswp-prev">« Prev</button>
            <span class="opacity-30">-</span>
            <button id="pswp-next">Next »</button>
          </div>
        </div>
      `,
      onInit: (el, pswp) => {
        el.querySelector('#pswp-prev').onclick = () => pswp.prev();
        el.querySelector('#pswp-next').onclick = () => pswp.next();
      }
    });

    lightbox.pswp?.ui?.registerElement({
      name: 'pagination',
      appendTo: 'wrapper',
      onInit: (el, pswp) => {
        pswp.on('change', () => {
          const curr = pswp.currIndex + 1;
          const total = pswp.getNumItems();
          el.innerText = `${curr < 10 ? '0' + curr : curr}/${total}`;
        });
      },
      html: '<div class="pswp__previews-count"></div>'
    });
  });

  lightbox.init();

  // Función para inyectar fotos en el Lightbox abierto
  window.refreshLightbox = (cards) => {
    const pswp = lightbox.pswp
    if (pswp) {
      pswp.options.dataSource?.items.push(...cards)
      pswp.refreshSlideContent(pswp.getNumItems() - 1);
    }
  };
</script>